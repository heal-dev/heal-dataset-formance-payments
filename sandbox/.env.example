# Sandbox inputs (copy to .env and fill). The local stack has NO auth, so the
# skeleton needs no credentials — these are stack knobs only.

# Public URL the payments app advertises for PSP webhooks/redirects. For the
# skeleton (no connector installed) any value works; localhost is fine.
STACK_PUBLIC_URL=http://localhost:8080

# Override the Console baseURL Playwright targets, if you remap ports.
# SANDBOX_BASE_URL=http://localhost:3000

# Postgres port (compose default 5432). Change only if it collides locally.
# POSTGRES_PORT=5432
